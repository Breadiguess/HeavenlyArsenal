Melee: {
	AvatarLonginus: {
		DisplayName: Dormant Splinter
		EmpoweredName: Unending Cycle of Retribution
		Tooltip:
			'''
			<left> Cycles through several extremely fast attacks.
			as you attack, you build up Heat. At max Heat, the Spear awakens and gains a new set of attacks
			<right> at any point will throw the spear
			The spear can pass through blocks, and will attempt to drag you to its location
			If thrown with over 50% Heat, you will create a small glowing orb that rapidly rakes into the hit target
			Once the orb collides, you teleport inside of the target, dealing massive damage.
			'''
	}

